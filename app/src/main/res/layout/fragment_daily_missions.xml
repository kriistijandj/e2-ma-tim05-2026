<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/AuthBackground"
    android:padding="16dp">

    <TextView
        style="@style/LoginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dnevne_misije"
        android:layout_marginBottom="4dp"
        android:textColor="@color/white"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Svaka rešena misija donosi 3 zvezde. Reši sve za bonus!"
        android:textSize="14sp"
        android:textColor="@color/textGray"
        android:layout_marginBottom="16dp"/>

    <!-- Dugme za testiranje u stilu tvojih filter dugmića -->
    <Button
        android:id="@+id/btnSimulateMission"
        style="@style/NotificationFilterBtn"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="[TEST] Simuliraj rešavanje jedne misije"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Misija 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="4dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <CheckBox
                    android:id="@+id/cbWonGame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="@string/pobedi_partiju"
                    android:textColor="@color/textDark"
                    android:buttonTint="@color/primaryDark"
                    android:clickable="false"
                    android:focusable="false"
                    android:textSize="16sp"/>
            </androidx.cardview.widget.CardView>

            <!-- Misija 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="4dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <CheckBox
                    android:id="@+id/cbSentMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="@string/po_alji_poruku_u_et"
                    android:textColor="@color/textDark"
                    android:buttonTint="@color/primaryDark"
                    android:clickable="false"
                    android:focusable="false"
                    android:textSize="16sp"/>
            </androidx.cardview.widget.CardView>

            <!-- Misija 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="4dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <CheckBox
                    android:id="@+id/cbPlayedFriendly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="@string/odigraj_prijateljsku_partiju"
                    android:textColor="@color/textDark"
                    android:buttonTint="@color/primaryDark"
                    android:clickable="false"
                    android:focusable="false"
                    android:textSize="16sp"/>
            </androidx.cardview.widget.CardView>

            <!-- Misija 4 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:layout_marginHorizontal="4dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <CheckBox
                    android:id="@+id/cbWonTournament"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="@string/pobedi_partiju_u_turniru"
                    android:textColor="@color/textDark"
                    android:buttonTint="@color/primaryDark"
                    android:clickable="false"
                    android:focusable="false"
                    android:textSize="16sp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Glavno dugme koje koristi tvoj stil za filtere ali je prošireno -->
    <Button
        android:id="@+id/btnClaimBonus"
        style="@style/NotificationFilterBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:text="@string/re_i_sve_misije_za_glavni_bonus"
        android:textSize="14sp"
        android:enabled="false" />

</LinearLayout>