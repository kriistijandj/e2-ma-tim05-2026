<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/AuthBackground"
    android:padding="20dp"
    tools:context=".fragments.LeaderboardFragment">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rang Lista"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutCycle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        app:tabTextColor="#90A4AE"
        app:tabSelectedTextColor="#F2AF14"
        app:tabIndicatorColor="#F2AF14">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nedeljna" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mesečna" />
    </com.google.android.material.tabs.TabLayout>

    <TextView
        android:id="@+id/tvCycleRange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ciklus: učitavanje..."
        android:textColor="#B0BEC5"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="#1E1E1E"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        tools:listitem="@layout/item_leaderboard_player"/>

</LinearLayout>