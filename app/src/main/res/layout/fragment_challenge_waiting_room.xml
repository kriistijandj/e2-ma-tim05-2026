<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Čekaonica izazova"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tvWaitingStake"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvWaitingStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:id="@+id/llParticipants"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginTop="12dp"/>

    <Button
        android:id="@+id/btnStartChallenge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pokreni izazov"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btnLeaveChallenge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Napusti čekaonicu"
        android:layout_marginTop="8dp"/>

</LinearLayout>
