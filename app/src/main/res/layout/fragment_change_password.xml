<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/AuthBackground"
    tools:context=".fragments.ChangePassword">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardChangePassword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/cardBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Naslov -->
            <TextView
                style="@style/LoginTitle"
                android:text="Promena lozinke" />

            <TextView
                style="@style/LoginSubtitle"
                android:text="Unesite staru lozinku i novu lozinku dva puta."
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Stara lozinka -->
            <EditText
                android:id="@+id/etOldPassword"
                style="@style/RoundedEditText"
                android:layout_marginBottom="12dp"
                android:hint="Stara lozinka"
                android:inputType="textPassword" />

            <!-- Nova lozinka -->
            <EditText
                android:id="@+id/etNewPassword"
                style="@style/RoundedEditText"
                android:layout_marginBottom="12dp"
                android:hint="Nova lozinka"
                android:inputType="textPassword" />

            <!-- Potvrda nove lozinke -->
            <EditText
                android:id="@+id/etConfirmPassword"
                style="@style/RoundedEditText"
                android:layout_marginBottom="24dp"
                android:hint="Ponovite novu lozinku"
                android:inputType="textPassword" />

            <!-- Dugme -->
            <Button
                android:id="@+id/btnChangePassword"
                style="@style/AuthButton"
                android:text="Sačuvaj promene" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>